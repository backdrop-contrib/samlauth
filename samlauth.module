<?php

/**
 * @file
 * Provides SAML authentication capabilities.
 */

/**
 * Implements hook_menu().
 */
function samlauth_menu() {
  $items = array();

  $items['admin/config/people/saml'] = array(
    'title' => 'SAML Authentication',
    'description' => 'Configure SAML authentication behaviors.',
    'page callback' => 'backdrop_get_form',
    'page arguments' => array('samlauth_configure_form'),
    'access arguments' => array('configure saml'),
    'type' => MENU_NORMAL_ITEM,
    'file' => 'samlauth.admin.inc',
  );
  
  
  
  

  $items['saml/metadata'] = array(
    'title' => 'SAML Metadata',
    'page callback' => 'samlauth_metadata',
    'access callback' => TRUE,
    'type' => MENU_CALLBACK,
  );

  $items['saml/login'] = array(
    'title' => 'SAML Login',
    'page callback' => 'samlauth_login',
    'access callback' => 'user_is_anonymous',
    'type' => MENU_CALLBACK,
  );

  $items['saml/logout'] = array(
    'title' => 'SAML Logout',
    'page callback' => 'samlauth_logout',
    // The logout process can always be started.
    'access callback' => TRUE,
    'type' => MENU_CALLBACK,
  );

  $items['saml/acs'] = array(
    'title' => 'SAML ACS',
    'page callback' => 'samlauth_acs',
    'access callback' => 'user_is_anonymous',
    'type' => MENU_CALLBACK,
  );

  $items['saml/sls'] = array(
    'title' => 'SAML SLS',
    'page callback' => 'samlauth_sls',
    'access callback' => 'user_is_anonymous',
    'type' => MENU_CALLBACK,
  );

  $items['saml/changepw'] = array(
    'title' => 'SAML Change Password',
    'page callback' => 'samlauth_changepw',
    'access callback' => 'user_is_logged_in',
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Implements hook_permission().
 */
function samlauth_permission() {
  return array(    
    'configure saml' => array(
      'title' => t('Configure SAML'),
      'description' => t('Configure SAML authentication behaviors'),
    ),
  );
}


/**
 * Implements hook_config_info().
 */
function samlauth_config_info() {
  $prefixes['samlauth.settings'] = array(
    'label' => t('SAML Authentication'),
    'group' => t('Configuration'),
  );
  return $prefixes;
}



/**
 * Implements hook_form_FORM_ID_alter for user_login.
 *
 * @param $form
 * @param $form_state
 */
function samlauth_form_user_login_alter(&$form, $form_state) {
  samlauth_login_form_alter($form, $form_state);
}

/**
 * Implements hook_form_FORM_ID_alter for user_login_block.
 *
 * @param $form
 * @param $form_state
 */
function samlauth_form_user_login_block_alter(&$form, $form_state) {
  samlauth_login_form_alter($form, $form_state);
}

/**
 * Implements hook_form_FORM_ID_alter for user_pass (password reset).
 *
 * @param $form
 * @param $form_state
 */
function samlauth_form_user_pass_alter(&$form, $form_state) {
  samlauth_login_form_alter($form, $form_state);
}

/**
 * Common callback for user_login_block / user_login / user_pass.
 */
function samlauth_login_form_alter(&$form, $form_state) {
  
  $form['mark_saml_button'] = array(
    '#markup' => "<div class='samlauth-access-button-wrapper'>
                            <a href='" . url("saml/login") . "' class='button-link samlauth-login-button'>" . t("Log in with SSO") . "</a>
                     <p class='access-desc'>" . t("Access using your organization's Single Sign-On authentication system.") . "</p>
                  </div>",
    '#weight' => -99,
  );
  
   
  $form['manual_fs'] = array(
    '#type' => 'fieldset',
    '#collapsible' => TRUE,
    '#collapsed' => TRUE,
    '#title' => t("Log in manually (non-SSO)"),
  );
  
  
  $form['manual_fs']['name'] = $form['name'];
  $form['manual_fs']['pass'] = $form['pass'];
  $form['manual_fs']['actions'] = $form['actions'];

  unset($form['name']);
  unset($form['pass']);
  unset($form['actions']);
  
  
  $form['#validate'][] = 'samlauth_check_saml_user';
}

/**
 * Validation callback for SAML users logging in through the normal login form.
 */
function samlauth_check_saml_user($form, $form_state) {
  if (!config_get('samlauth.settings', 'samlauth_backdrop_saml_login', FALSE)) {
    if (form_get_errors()) {
      // If previous validation functions have already failed (name/pw incorrect
      // or blocked), bail out so we don't disclose any details about a user that
      // otherwise wouldn't be authenticated.
      return;
    }

    $account = user_load_by_name($form_state['values']['name']);
    if (!$account) {
      $account = user_load_by_mail($form_state['values']['name']);
    }
    if (!$account) {
      form_set_error('name', t('Could not load user to do a validation check.'));
    }
    else {
      $saml_id = samlauth_find_unique_id_by_user_id($account->uid);
      if ($saml_id !== FALSE) {
        form_set_error('name', t('Single-Sign On users must sign in with SSO.'));
      }
    }
  }
}

/**
 * Returns configuration array for SAML SP.
 *
 * @return array
 */
function samlauth_get_config() {
  $config = array(
    'baseurl' => url('saml', array('absolute' => TRUE)) . '/',
    'strict' => (bool) config_get('samlauth.settings', 'samlauth_security_strict'),
    'sp' => array(
      'entityId' => config_get('samlauth.settings', 'samlauth_sp_entity_id'),
      'assertionConsumerService' => array(
        'url' => url('saml/acs', array('absolute' => TRUE)),
      ),
      'singleLogoutService' => array(
        'url' => url('saml/sls', array('absolute' => TRUE)),
      ),
      'NameIDFormat' => config_get('samlauth.settings', 'samlauth_sp_name_id_format'),
      'x509cert' => config_get('samlauth.settings', 'samlauth_sp_x509_certificate'),
      'privateKey' => config_get('samlauth.settings', 'samlauth_sp_private_key'),
    ),
    'idp' => array(
      'entityId' => config_get('samlauth.settings', 'samlauth_idp_entity_id'),
      'singleSignOnService' => array(
        'url' => config_get('samlauth.settings', 'samlauth_idp_single_sign_on_service'),
      ),
      'singleLogoutService' => array(
        'url' => config_get('samlauth.settings', 'samlauth_idp_single_log_out_service'),
      ),
      'x509cert' => config_get('samlauth.settings', 'samlauth_idp_x509_certificate'),
    ),
    'security' => array(
      'authnRequestsSigned' => (bool) config_get('samlauth.settings', 'samlauth_security_authn_requests_sign'),
      'logoutRequestSigned' => (bool) config_get('samlauth.settings', 'samlauth_logout_requests_sign'),
      'logoutResponseSigned' => (bool) config_get('samlauth.settings', 'samlauth_logout_responses_sign'),
      'wantMessagesSigned' => (bool) config_get('samlauth.settings', 'samlauth_security_messages_sign'),
      'wantAssertionsSigned' => (bool) config_get('samlauth.settings', 'samlauth_security_assertions_signed'),
      'wantAssertionsEncrypted' => (bool) config_get('samlauth.settings', 'samlauth_security_assertions_encrypted'),
      'wantNameId' => (bool) config_get('samlauth.settings', 'samlauth_want_name_id'),
      'requestedAuthnContext' => (bool) config_get('samlauth.settings', 'samlauth_security_request_authn_context'),
      'lowercaseUrlencoding' => (bool) config_get('samlauth.settings', 'samlauth_lowercase_url_encoding'),
    ),
  );
  // Passing NULL for signatureAlgorithm would be OK, but not ''.
  $sig_alg = config_get('samlauth.settings', 'samlauth_security_security_signature_algorithm');
  if ($sig_alg) {
    $config['security']['signatureAlgorithm'] = $sig_alg;
  }

  return $config;
}

/**
 * Get an instance of the SAML Auth class.
 *
 * @return \OneLogin\Saml2\Auth
 *   The SAML Auth library object.
 */
function samlauth_get_saml2_auth() {
  samlauth_init_onelogin_library();
  return new OneLogin\Saml2\Auth(samlauth_get_config());
}




/**
 * This function will include the onelogin php-saml library that we need for this
 * module to function.
 */
function samlauth_init_onelogin_library() {
  require_once(backdrop_get_path('module', 'samlauth') . '/lib/onelogin/vendor/autoload.php');
}





/**
 * Menu callback for /saml/metadata.
 */
function samlauth_metadata() {
  $auth = samlauth_get_saml2_auth();
  $settings = $auth->getSettings();
  $metadata = $settings->getSPMetadata();
  $errors = $settings->validateMetadata($metadata);

  if (!empty($errors)) {
    throw new Exception('Invalid SP metadata: ' . implode(', ', $errors));
  }

  backdrop_add_http_header('Content-Type', 'text/xml');

  // @TODO: This is gross. Investigate using a delivery callback instead.
  print $metadata;
  backdrop_exit();
}

/**
 * Menu callback for /saml/login.
 */
function samlauth_login() {
  $auth = samlauth_get_saml2_auth();
  $auth->login(_samlauth_pre_destination_url(), array(), FALSE, FALSE, FALSE, config_get('samlauth.settings', 'samlauth_set_nameidpolicy'));
}

/**
 * Menu callback for /saml/logout.
 */
function samlauth_logout() {
  $nameId = isset($_SESSION['samlauth']['nameId']) ? $_SESSION['samlauth']['nameId'] : NULL;
  $nameIdFormat = isset($_SESSION['samlauth']['nameIdFormat']) ? $_SESSION['samlauth']['nameIdFormat'] : NULL;
  $nameIdNameQualifier = isset($_SESSION['samlauth']['nameIdNameQualifier']) ? $_SESSION['samlauth']['nameIdNameQualifier'] : NULL;
  $sessionIndex = isset($_SESSION['samlauth']['sessionIndex']) ? $_SESSION['samlauth']['sessionIndex'] : NULL;

  if (user_is_logged_in()) {
    module_load_include('pages.inc', 'user');
    user_logout_current_user();
  }

  // Check if there is a SAML response already. We have no way of verifying the
  // response because SAML PHP processResponse() does not support logout
  // responses and processSlo() only looks at GET parameters.
  if (isset($_POST['SAMLResponse'])) {
    // Just assume everything went well and go to the frontpage.
    backdrop_goto();
  }
  else {
    // Redirect to the auth server for logout.
    $auth = samlauth_get_saml2_auth();
    $auth->logout(_samlauth_pre_destination_url(), array(), $nameId, $sessionIndex, FALSE, $nameIdFormat, $nameIdNameQualifier);
  }
}

/**
 * Constructs a full URL from the 'destination' request parameter.
 *
 * @return string|null
 *   The full absolute URL (i.e. our hostname plus the path in the destination
 *   parameter), or NULL if no destination parameter was given. This value is
 *   tuned to what login() / logout() expect for an input argument.
 */
function _samlauth_pre_destination_url() {
  return isset($_REQUEST['destination']) ? url($_REQUEST['destination'], ['absolute' => TRUE]) : NULL;
}

/**
 * Returns a URL to redirect to, after processing an ACS/logout response.
 *
 * @param bool $processing_error
 *   (Optional) true if an error was encountered while processing the response.
 *
 * @return string
 *   The URL to redirect to.
 */
function _samlauth_destination_url($processing_error = FALSE) {
  // We should be able to trust the RelayState parameter at this point
  // because the response from the IDP was verified - but check protocol.
  return isset($_REQUEST['RelayState']) && !$processing_error
    ? backdrop_strip_dangerous_protocols($_REQUEST['RelayState']) : '<front>';
}

/**
 * Menu callback for /saml/sls.
 */
function samlauth_sls() {
  $url = '';

  try {
    // There are two valid cases here:
    // - We're processing a LogoutRequest, which will return a URL to redirect
    //   to (which is the IdP); the RelayState is not for us.
    // - We're processing a LogoutResponse, which will return NULL; the
    //   RelayState is meant for us to process.
    $auth = samlauth_get_saml2_auth();
    $url = $auth->processSLO(FALSE, NULL, (bool) config_get('samlauth.settings', 'samlauth_logout_reuse_sigs'), NULL, TRUE);
    $errors = $auth->getErrors();

    if (empty($errors)) {
      // Log out the user, since the logout already happened on the server.
      if (user_is_logged_in()) {
        module_load_include('pages.inc', 'user');
        user_logout_current_user();
      }
    } else {
      backdrop_set_message('SLS error: ' . implode(', ', $errors), 'error');
    }
  } catch (Exception $e) {
    backdrop_set_message('SLS error: ' . $e->getMessage(), 'error');
    $errors = TRUE;
  }

  backdrop_goto($url ?: _samlauth_destination_url(!empty($errors)));
}

/**
 * Menu callback for /saml/changepw.
 */
function samlauth_changepw() {
  $changepw_service = config_get('samlauth.settings', 'samlauth_change_password_service');

  if ($changepw_service === FALSE) {
    backdrop_set_message('The site administrator has not configured a password change service. Please change your password according to the normal processes in your organization.', 'error');
    backdrop_goto();
  }

  backdrop_goto(config_get('samlauth.settings', 'samlauth_change_password_service'), array('external' => TRUE));
}

/**
 * Menu callback for /saml/acs.
 */
function samlauth_acs() {
  
  $account = FALSE;  
  
  $logout_link = l("[SSO Log out]", "saml/logout");
  
  if (!isset($_POST['SAMLResponse'])) {
    watchdog('samlauth', 'Attempted to access /saml/acs, but SAMLResponse was not found in POST.
                        Value of POST:<pre>' . print_r($_POST, TRUE) . '</pre>', array(), WATCHDOG_DEBUG);
    backdrop_set_title(t('Single Sign-On Unsuccessful'));
    return t("<p>Sorry, there has been an error attempting to sign on. The following information on this page may help debug the issue:
                 <br>HTTP_POST SAMLResponse not found. Only HTTP_POST binding is supported.</p>
                 <p>If you continue to see this message, contact your IT or system administrator.</p>") . $logout_link;     


  }
  
  
  try {
    $auth = samlauth_get_saml2_auth();
    $auth->processResponse();
    $errors = $auth->getErrors();

    if (!empty($errors)) {
      throw new Exception('ACS error: ' . implode(', ', $errors));
    }

    if (!$auth->isAuthenticated()) {
      throw new Exception('SAML user is not authenticated.');
    }

    // Get the attributes returned by the IdP. Having them keyed by both name
    // and friendly name is likely easier for code, but means that this cannot
    // be treated as a single set of unique attributes; values are duplicated.
    $saml_data = $auth->getAttributes() + $auth->getAttributesWithFriendlyName();
    $saml_data['response__NameID'] = array($auth->getNameID());  // Always add the nameID to the response, in case another module needs it.
    
    
    $bool_log = (bool) config_get('samlauth.settings','samlauth_watchdog_requests');
    
    if ($bool_log) {
      watchdog('samlauth', "Received SAML response: " . print_r($saml_data, TRUE), array(), WATCHDOG_DEBUG);
    }

  }
  catch (Exception $e) {
    watchdog_exception('samlauth', $e);
    backdrop_set_title(t('Single Sign-On Unsuccessful'));
    return t("<p>Sorry, there has been an error attempting to sign on. If you continue to see this message, contact your IT or system administrator.</p>") . $logout_link;     
   
  }

  ////////////////////////
  // If we made it here, we can continue trying to find the user.  
  $email_attr = config_get('samlauth.settings', 'samlauth_unique_id_attribute');
    

  // Go through all our results, looking for the one that *ends* with the unique attribute (AKA the email attribute).
  $bool_found_it = FALSE;
  $user_email = '';
  if ($email_attr) {
    foreach ($saml_data as $key => $val) {
      if (str_ends_with($key, $email_attr)) {
        $bool_found_it = TRUE;
        $user_email = trim($val[0]);
      }
    }
  }
  
  
    
  if ($user_email) {
    // Meaning, we found a value for email.  Does this user exist in Backdrop?
    
    // Do we have an allowlist set up, and is this user in it?
    $allowlist = trim(config_get('samlauth.settings', 'samlauth_allowlist_emails') ?? '');    
    if ($allowlist) {
      $bool_is_allowed = FALSE;
      $lines = explode("\n", $allowlist);
      foreach ($lines as $line) {
        $line = trim(strtolower($line));
        if ($line == trim(strtolower($user_email))) {
          $bool_is_allowed = TRUE;
          break;
        }
      }
      
      if (!$bool_is_allowed) {
        watchdog("samlauth", "User with email: $user_email not specified in allowlist. Login rejected.", array(), WATCHDOG_ALERT);
        backdrop_set_title(t('Single Sign-On Unsuccessful'));
        return t("<p>Sorry, but this system is currently only allowing certain users. Your email address ($user_email) was not found in the allowlist.
                            If you believe you need access, contact your IT or system administrator.</p>") . $logout_link;
        
      }
      
    }
    
    
    
    // TODO: Shouldn't we check to see if the user can be created upon first login? That is a setting: samlauth_create_users (boolean or 1/0)
    
    
    $account = user_load_by_mail($user_email);
    if (!$account || intval($account->status ?? 0) != 1) {
      watchdog("samlauth", "User with email: $user_email not found in users table. Login failed.", array(), WATCHDOG_ALERT);
      backdrop_set_title(t('Single Sign-On Unsuccessful'));
      return t("<p>Sorry, but a user with your email address ($user_email) was not found in this system.
                            If you believe you need access, contact your IT or system administrator.</p>") . $logout_link;     
    }
    
  } // if user_email
  
  
  ////////////////////////////////////////
  
  // If we are here, then we are good to continue and actually log the user in!    
  global $user;
  $user = $account;

  user_login_finalize();

  // Store the authentication details in the user's session, we need it later
  // when logging out.
  
  // TODO: not sure I need any of this with the session vars...  
  $_SESSION['samlauth']['nameId'] = $auth->getNameId();
  $_SESSION['samlauth']['nameIdFormat'] = $auth->getNameIdFormat();
  $_SESSION['samlauth']['nameIdNameQualifier'] = $auth->getNameIdNameQualifier();
  $_SESSION['samlauth']['sessionIndex'] = $auth->getSessionIndex();

  //backdrop_goto(_samlauth_destination_url());
  
  backdrop_goto("<front>");
  
  
}

/**
 * Find a user given the unique ID from the SAML IdP.
 *
 * @param $id
 *
 * @return int
 *   Returns the uid of the user with the unique ID.
 */
function samlauth_find_uid_by_unique_id($id) {
  return db_select('authmap', 'a')
    ->fields('a', array('uid'))
    ->condition('authname', $id)
    ->condition('module', 'samlauth')
    ->execute()
    ->fetchField();
}

/**
 * Find a unique id from a username.
 */
function samlauth_find_unique_id_by_user_id($uid) {
  return db_select('authmap', 'a')
    ->fields('a', array('authname'))
    ->condition('module', 'samlauth')
    ->condition('uid', $uid)
    ->execute()
    ->fetchField();
}

/**
 * Ensure that a SAML ID is associated with a given user account.
 *
 * @param $saml_id
 * @param \Backdrop\Core\Session\AccountInterface $account
 */
function samlauth_associate_saml_id_with_account($saml_id, $account) {
  $uid = samlauth_find_uid_by_unique_id($saml_id);
  if ($uid == NULL) {
    db_insert('authmap')
      ->fields(array(
        'uid' => $account->uid,
        'authname' => $saml_id,
        'module' => 'samlauth',
      ))
      ->execute();
  }
  else {
    db_update('authmap')
      ->fields(array(
        'uid' => $account->uid,
        'authname' => $saml_id,
        'module' => 'samlauth',
      ))
      ->condition('uid', $account->uid)
      ->condition('module', 'samlauth')
      ->execute();
  }
}

/**
 * Create a new user from SAML response data.
 *
 * @param $saml_data
 */
function samlauth_create_user_from_saml_data($saml_data) {
  $user_unique_attribute = config_get('samlauth.settings', 'samlauth_unique_id_attribute');
  $user_name_attribute = config_get('samlauth.settings', 'samlauth_user_name_attribute');
  $user_mail_attribute = config_get('samlauth.settings', 'samlauth_user_mail_attribute');
  if (!isset($saml_data[$user_name_attribute][0])) {
    throw new Exception('Missing name attribute in SAML response.');
  }
  if (!isset($saml_data[$user_mail_attribute][0])) {
    throw new Exception('Missing mail attribute in SAML response.');
  }

  $account = new stdClass();
  $account->name = $saml_data[$user_name_attribute][0];
  $account->pass = user_password(50);
  $account->mail = $saml_data[$user_mail_attribute][0];
  $account->status = 1;

  // Fix timezone warning when creating new user.
  //$account->timezone = variable_get('date_default_timezone', 0);
  $account->timezone = config_get('system.date', 'default_timezone');

  // Allow other modules to change/set user properties before saving.
  backdrop_alter('samlauth_new_user', $account, $saml_data);

  user_save($account);

  samlauth_associate_saml_id_with_account($saml_data[$user_unique_attribute][0], $account);

  return $account;
}
